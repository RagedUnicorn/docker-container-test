{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "on monday"
  ],
  "timezone": "UTC",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "ARG CONTAINER_STRUCTURE_VERSION=(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "GoogleContainerTools/container-structure-test",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Keep the Alpine base.name OCI label in the Dockerfile in sync with the FROM version",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "alpine",
      "versioningTemplate": "docker",
      "matchStrings": [
        "image\\.base\\.name=\"docker\\.io/library/alpine:(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "description": "Keep the Alpine version in the metadata test in sync with the FROM version",
      "managerFilePatterns": [
        "/^test/container_test_metadata_test\\.yml$/"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "alpine",
      "versioningTemplate": "docker",
      "matchStrings": [
        "docker\\.io/library/alpine:(?<currentValue>[^']+)'"
      ]
    }
  ],
  "ignorePaths": [
    "docker-compose.yml",
    "docker-compose.dev.yml",
    "docker-compose.test.yml"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "commitMessagePrefix": "chore(deps):",
  "prConcurrentLimit": 2,
  "prCreation": "immediate",
  "automerge": false,
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "alpine"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": false
    }
  ]
}
